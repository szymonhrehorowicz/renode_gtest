# Filename: renode-config.resc
$bin = "C:/_git/renode_stm32/build/fw-Sim/target/target.elf"

# Create Machine & Load config
mach create
machine LoadPlatformDescription "C:/_git/renode_stm32/stm32f4.repl"

# Enable Function Tracking
# sysbus.cpu LogFunctionNames true
sysbus LogAllPeripheralsAccess true
# gpioPortC LogRegisterWrite true

macro reset
"""
    sysbus LoadELF $bin
"""

runMacro $reset

emulation CreateServerSocketTerminal 12345 "term" false
connector Connect sysbus.uart4 term

machine StartGdbServer 1235 true
start